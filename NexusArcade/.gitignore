# --- Security / Sensitive Data ---
# NEVER remove these. They protect your wallet and API keys.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Dependencies ---
# These are huge and should be installed via 'npm install' instead of tracked
node_modules/
jspm_packages/

# --- Hardhat / Smart Contracts ---
# These are generated automatically when you compile/deploy
artifacts/
cache/
typechain/
typechain-types/
coverage/
coverage.json
.openzeppelin/

# --- Backend / Databases ---
# Prevents your local database from being uploaded
*.sqlite
*.sqlite3
*.db
*.db-journal

# --- Frontend / Build ---
# These are generated when you run 'npm run build'
/build
/dist
/out
.next/
.expo/

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- IDE / System Files ---
.vscode/
.idea/
.DS_Store
Thumbs.db